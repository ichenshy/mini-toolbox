.privacy-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 99999;
  background: rgba(44, 36, 22, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.privacy-dialog {
  width: 100%;
  max-width: 620rpx;
  background: #fffcf7;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(120, 90, 50, 0.12);
  box-shadow: 0 16rpx 40rpx rgba(90, 60, 30, 0.18);
}

.privacy-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #2c2416;
}

.privacy-content {
  display: block;
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(74, 58, 36, 0.68);
}

.privacy-link {
  color: #9a7b4f;
}

.privacy-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.privacy-btn {
  flex: 1;
  margin: 0;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn-cancel {
  background: #efe6d8;
  color: #2c2416;
}

.privacy-btn-ok {
  background: #9a7b4f;
  color: #fff;
}
