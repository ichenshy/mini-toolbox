<view class="page" style="{{pageStyleGlobal}}">
  <view class="header">
    <view class="nav-row">
      <view class="nav-back" bindtap="goBack">‹</view>
      <view class="header-text">
        <text class="title">阅读历史</text>
        <text class="subtitle">打开过的 Markdown 会保存在本地</text>
      </view>
    </view>
  </view>

  <view class="content">
    <view class="history-list" wx:if="{{historyList.length > 0}}">
      <block wx:for="{{historyList}}" wx:key="filePath">
        <view class="theme-card history-item">
          <view class="file-info">
            <text class="file-name">{{item.fileName}}</text>
            <view class="file-details">
              <text class="file-size">{{item.fileSize}}</text>
              <text class="file-date">{{item.createTime}}</text>
            </view>
            <text class="file-path" selectable="true">{{item.filePath}}</text>
          </view>
          <view class="file-actions">
            <view
              class="chip chip-primary"
              bindtap="openMarkdown"
              data-file-path="{{item.filePath}}"
              data-file-name="{{item.fileName}}"
            >打开</view>
            <view
              class="chip chip-danger"
              bindtap="deleteMarkdown"
              data-file-path="{{item.filePath}}"
              data-file-name="{{item.fileName}}"
            >删除</view>
          </view>
        </view>
      </block>
    </view>

    <view class="theme-card empty-card" wx:else>
      <text class="empty-title">暂无阅读历史</text>
      <text class="empty-desc">打开过的 Markdown 文档会出现在这里</text>
      <view class="empty-btn" bindtap="goBack">返回预览</view>
    </view>
  </view>

  <view class="footer" wx:if="{{historyList.length > 0}}">
    <view class="footer-btn footer-btn-secondary" bindtap="goBack">返回</view>
    <view class="footer-btn footer-btn-danger" bindtap="clearAllHistory">清空所有历史</view>
  </view>
</view>
