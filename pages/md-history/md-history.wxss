.page {
  min-height: 100vh;
  width: 100%;
  background: var(--paper);
  padding: var(--status-bar-height) 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.header {
  padding: 16rpx 24rpx 12rpx;
}

.nav-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  line-height: 1;
  color: var(--ink);
  flex-shrink: 0;
  margin-top: -4rpx;
}

.header-text {
  flex: 1;
  min-width: 0;
  padding-top: 6rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.4rpx;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: var(--ink-soft);
}

.content {
  flex: 1;
  min-height: 0;
  padding: 12rpx 32rpx 220rpx;
  box-sizing: border-box;
  width: 100%;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.history-item {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 14rpx;
  word-break: break-all;
  line-height: 1.35;
}

.file-details {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx 16rpx;
}

.file-size {
  font-size: 22rpx;
  background: var(--paper-deep);
  color: var(--ink-soft);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  line-height: 1.4;
}

.file-date {
  font-size: 22rpx;
  color: var(--ink-soft);
  line-height: 1.4;
}

.file-path {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--ink-soft);
  line-height: 1.4;
  word-break: break-all;
}

.file-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
  width: 128rpx;
}

.chip {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.chip:active {
  opacity: 0.82;
}

.chip-primary {
  background: var(--accent);
  color: #fff;
}

.chip-danger {
  background: var(--danger-soft);
  color: var(--danger);
}

.empty-card {
  margin-top: 80rpx;
  padding: 64rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.empty-title {
  display: block;
  width: 100%;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  width: 100%;
  font-size: 26rpx;
  color: var(--ink-soft);
  margin-bottom: 36rpx;
  line-height: 1.45;
  word-break: break-word;
}

.empty-btn {
  width: 100%;
  max-width: 360rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--accent);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-btn:active {
  opacity: 0.88;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(246, 241, 232, 0.96);
  backdrop-filter: saturate(180%) blur(18px);
  -webkit-backdrop-filter: saturate(180%) blur(18px);
  border-top: 0.5px solid var(--card-line);
  display: flex;
  gap: 16rpx;
  box-sizing: border-box;
}

.footer-btn {
  flex: 1;
  width: 0;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.footer-btn:active {
  opacity: 0.88;
}

.footer-btn-secondary {
  background: var(--paper-deep);
  color: var(--ink);
}

.footer-btn-danger {
  background: var(--danger);
  color: #fff;
}
