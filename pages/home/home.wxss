.page {
  min-height: 100vh;
  background: var(--paper);
  padding: var(--status-bar-height) 40rpx 48rpx;
  box-sizing: border-box;
}

.hero {
  padding: 72rpx 8rpx 48rpx;
}

.brand {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -1rpx;
  line-height: 1.15;
}

.tagline {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: var(--ink-soft);
}

.tool-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.tool-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 28rpx;
}

.tool-card:active {
  opacity: 0.88;
  transform: scale(0.99);
}

.tool-mark {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.pdf-mark {
  background: var(--accent-soft);
  color: var(--accent);
}

.md-mark {
  background: rgba(120, 90, 50, 0.1);
  color: #7a6240;
}

.tool-body {
  flex: 1;
  min-width: 0;
}

.tool-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.3;
}

.tool-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--ink-soft);
}

.tool-arrow {
  flex-shrink: 0;
  font-size: 44rpx;
  line-height: 1;
  color: var(--ink-faint);
  padding-bottom: 4rpx;
}
