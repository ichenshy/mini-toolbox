.page {
  height: 100vh;
  min-height: 100vh;
  width: 100%;
  background: var(--paper);
  padding: var(--status-bar-height) 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.header {
  padding: 16rpx 24rpx 20rpx;
  padding-right: var(--capsule-right, 200rpx);
  box-sizing: border-box;
}

.nav-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  line-height: 1;
  color: var(--ink);
  flex-shrink: 0;
  margin-top: -4rpx;
}

.header-text {
  flex: 1;
  min-width: 0;
  padding-top: 6rpx;
  padding-right: 12rpx;
}

.history-entry {
  flex-shrink: 0;
  margin-top: 10rpx;
  padding: 10rpx 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent);
  background: var(--accent-soft);
  border-radius: 999rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--ink-soft);
}

.mode-switch {
  display: flex;
  margin-top: 24rpx;
  margin-left: 8rpx;
  margin-right: 8rpx;
  background: rgba(154, 123, 79, 0.12);
  border-radius: 20rpx;
  padding: 4rpx;
  height: 68rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 252, 247, 0.7);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
}

.mode-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--ink-soft);
  border-radius: 16rpx;
}

.mode-item.active {
  background: var(--card);
  color: var(--ink);
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(90, 60, 30, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 252, 247, 0.95);
}

.content {
  flex: 1;
  min-height: 0;
  height: 0;
  width: 100%;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
}

.preview-scroll {
  height: 100%;
  width: 100%;
}

.document-body {
  padding-top: 4rpx;
}

.md-card {
  padding: 28rpx 30rpx;
  margin: 0;
}

.source-group {
  margin: 0;
  padding: 0;
}

.source-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: var(--paper-deep);
  border-bottom: 0.5px solid var(--card-line);
}

.source-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-soft);
  letter-spacing: 1rpx;
}

.scroll-bottom-safe {
  height: 48rpx;
}

.copy-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 14rpx;
  border: 0.5px solid rgba(255, 255, 255, 0.22);
}

.copy-btn:active {
  background: rgba(255, 255, 255, 0.28);
}

.copy-btn-light {
  background: rgba(154, 123, 79, 0.12);
  border: 0.5px solid rgba(154, 123, 79, 0.22);
}

.copy-btn-light:active {
  background: rgba(154, 123, 79, 0.22);
}

.copy-icon {
  position: relative;
  width: 28rpx;
  height: 32rpx;
}

.copy-icon-back {
  position: absolute;
  top: 0;
  left: 6rpx;
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 4rpx;
}

.copy-icon-front {
  position: absolute;
  top: 8rpx;
  left: 0;
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid #fff;
  border-radius: 4rpx;
  background: #2a241c;
}

.copy-icon-light .copy-icon-back {
  border-color: var(--accent);
}

.copy-icon-light .copy-icon-front {
  border-color: var(--accent);
  background: var(--paper-deep);
}

.source-text {
  display: block;
  padding: 28rpx;
  white-space: pre-wrap;
  word-break: break-word;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--ink);
  font-family: "SF Mono", ui-monospace, Menlo, Monaco, Consolas, monospace;
}

.state-card {
  width: 100%;
  max-width: 100%;
  margin-top: 24rpx;
  padding: 64rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.state-text,
.empty-title,
.empty-desc {
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  word-break: break-word;
  white-space: normal;
}

.state-text {
  font-size: 28rpx;
  color: var(--ink-soft);
  line-height: 1.47;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--ink-soft);
  margin-bottom: 28rpx;
}

.action-btn {
  margin: 0;
  width: 100%;
  max-width: 420rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  line-height: 1.4;
}
