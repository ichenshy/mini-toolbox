.page {
  height: 100vh;
  min-height: 100vh;
  width: 100%;
  background: var(--paper);
  padding: var(--status-bar-height) 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.header {
  padding: 16rpx 24rpx 20rpx;
}

.nav-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  line-height: 1;
  color: var(--ink);
  flex-shrink: 0;
  margin-top: -4rpx;
}

.header-text {
  flex: 1;
  min-width: 0;
  padding-top: 6rpx;
  padding-right: 12rpx;
}

.history-entry {
  flex-shrink: 0;
  margin-top: 10rpx;
  padding: 10rpx 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent);
  background: var(--accent-soft);
  border-radius: 999rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: var(--ink-soft);
}

.mode-switch {
  display: flex;
  margin-top: 24rpx;
  margin-left: 8rpx;
  margin-right: 8rpx;
  background: rgba(154, 123, 79, 0.12);
  border-radius: 20rpx;
  padding: 4rpx;
  height: 68rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 252, 247, 0.7);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
}

.mode-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--ink-soft);
  border-radius: 16rpx;
}

.mode-item.active {
  background: var(--card);
  color: var(--ink);
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(90, 60, 30, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 252, 247, 0.95);
}

.content {
  flex: 1;
  min-height: 0;
  height: 0;
  width: 100%;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
}

.preview-scroll {
  height: 100%;
  width: 100%;
}

.document-body {
  padding-top: 4rpx;
}

.text-group {
  padding: 28rpx 30rpx;
  margin: 0 0 18rpx;
}

.code-group {
  margin: 0 0 18rpx;
}

.quote-group {
  padding: 24rpx 28rpx 24rpx 24rpx;
  margin: 0 0 18rpx;
  border-left: 8rpx solid #d4b896;
  background: #fff9f0;
}

.source-group {
  margin: 0;
  padding: 0;
}

.source-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: var(--paper-deep);
  border-bottom: 0.5px solid var(--card-line);
}

.source-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-soft);
  letter-spacing: 1rpx;
}

.scroll-bottom-safe {
  height: 48rpx;
}

.md-heading {
  margin: 12rpx 0 8rpx;
  padding: 0 4rpx;
}

.heading-text {
  display: block;
  color: var(--ink);
}

.heading-text.level-1 {
  font-size: 40px;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.4px;
  margin-top: 4px;
}

.heading-text.level-2 {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: -0.3px;
  margin-top: 20px;
}

.heading-text.level-3 {
  font-size: 22px;
  font-weight: 600;
  line-height: 1.3;
  margin-top: 16px;
}

.heading-text.level-4,
.heading-text.level-5,
.heading-text.level-6 {
  font-size: 17px;
  font-weight: 600;
  line-height: 1.35;
  color: var(--ink-soft);
  margin-top: 14px;
}

.md-paragraph {
  display: block;
  font-size: 17px;
  line-height: 1.55;
  color: var(--ink);
  margin: 0;
  letter-spacing: -0.1px;
}

.code-block {
  background: #2a241c;
  border-radius: 22rpx;
  padding: 24rpx 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 245, 230, 0.08);
  box-shadow: 0 12rpx 36rpx rgba(40, 28, 16, 0.22);
}

.code-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.code-lang {
  font-size: 22rpx;
  color: rgba(245, 230, 210, 0.55);
  letter-spacing: 1rpx;
  text-transform: uppercase;
  font-weight: 600;
}

.copy-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 14rpx;
  border: 0.5px solid rgba(255, 255, 255, 0.22);
}

.copy-btn:active {
  background: rgba(255, 255, 255, 0.28);
}

.copy-btn-light {
  background: rgba(154, 123, 79, 0.12);
  border: 0.5px solid rgba(154, 123, 79, 0.22);
}

.copy-btn-light:active {
  background: rgba(154, 123, 79, 0.22);
}

.copy-icon {
  position: relative;
  width: 28rpx;
  height: 32rpx;
}

.copy-icon-back {
  position: absolute;
  top: 0;
  left: 6rpx;
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 4rpx;
}

.copy-icon-front {
  position: absolute;
  top: 8rpx;
  left: 0;
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid #fff;
  border-radius: 4rpx;
  background: #2a241c;
}

.copy-icon-light .copy-icon-back {
  border-color: var(--accent);
}

.copy-icon-light .copy-icon-front {
  border-color: var(--accent);
  background: var(--paper-deep);
}

.code-content {
  display: block;
}

.table-group {
  padding: 0;
  margin: 0 0 18rpx;
}

.table-scroll {
  width: 100%;
}

.table-wrap {
  display: block;
  overflow: hidden;
}

.table-row {
  display: flex;
  width: 100%;
}

.table-header {
  background: var(--paper-deep);
}

.table-header .table-cell {
  color: var(--ink-soft);
  font-weight: 600;
  font-size: 24rpx;
  background: var(--paper-deep);
}

.table-cell {
  flex: none;
  padding: 20rpx 18rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: var(--ink);
  border-bottom: 0.5px solid var(--card-line);
  border-right: 0.5px solid var(--card-line);
  word-break: break-word;
  white-space: normal;
  background: var(--card);
  box-sizing: border-box;
  overflow: hidden;
}

.table-row .table-cell:last-child {
  border-right: none;
}

.table-wrap .table-row:last-child .table-cell {
  border-bottom: none;
}

.list-group {
  padding: 16rpx 28rpx;
  margin: 0 0 18rpx;
}

.list-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.list-row + .list-row {
  border-top: 0.5px solid var(--card-line);
}

.list-marker {
  flex-shrink: 0;
  min-width: 48rpx;
  margin-right: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--accent);
  line-height: 1.47;
  font-variant-numeric: tabular-nums;
}

.list-marker.dot {
  min-width: 32rpx;
  font-size: 34rpx;
  font-weight: 400;
  color: var(--ink-faint);
  text-align: center;
}

.list-marker.ordered {
  color: var(--ink);
  font-weight: 600;
}

.list-text {
  flex: 1;
  font-size: 34rpx;
  line-height: 1.47;
  color: var(--ink);
  font-weight: 500;
}

.md-blockquote {
  display: block;
  font-size: 34rpx;
  line-height: 1.55;
  color: var(--ink-soft);
}

.md-spacer {
  height: 1rpx;
  background: var(--card-line);
  margin: 20rpx 8rpx 28rpx;
}

.source-text {
  display: block;
  padding: 28rpx;
  white-space: pre-wrap;
  word-break: break-word;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--ink);
  font-family: "SF Mono", ui-monospace, Menlo, Monaco, Consolas, monospace;
}

.state-card {
  width: 100%;
  max-width: 100%;
  margin-top: 24rpx;
  padding: 64rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.state-text,
.empty-title,
.empty-desc {
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  word-break: break-word;
  white-space: normal;
}

.state-text {
  font-size: 28rpx;
  color: var(--ink-soft);
  line-height: 1.47;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--ink-soft);
  margin-bottom: 28rpx;
}

.action-btn {
  margin: 0;
  width: 100%;
  max-width: 420rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  line-height: 1.4;
}

.secondary-btn {
  margin-top: 16rpx;
}
