.page {
  min-height: 100vh;
  background: var(--paper);
  padding: var(--status-bar-height) 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 16rpx 24rpx 8rpx;
}

.nav-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  line-height: 1;
  color: var(--ink);
  flex-shrink: 0;
  margin-top: -4rpx;
}

.header-text {
  flex: 1;
  min-width: 0;
  padding-top: 6rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.4rpx;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: var(--ink-soft);
}

.content {
  flex: 1;
  padding: 20rpx 32rpx 420rpx;
  box-sizing: border-box;
}

.gallery-card {
  padding: 0 0 28rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: var(--paper-deep);
  border-bottom: 0.5px solid var(--card-line);
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
}

.card-meta {
  font-size: 24rpx;
  color: var(--ink-soft);
}

.format-tip {
  padding: 18rpx 28rpx 0;
}

.format-tip-main,
.format-tip-sub {
  display: block;
  font-size: 22rpx;
  line-height: 1.5;
}

.format-tip-main {
  color: var(--ink);
}

.format-tip-sub {
  margin-top: 6rpx;
  color: var(--ink-soft);
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 28rpx 24rpx 0;
  position: relative;
  min-height: 280rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  overflow: hidden;
  z-index: 1;
  border: 1rpx solid var(--card-line);
  box-shadow: 0 6rpx 16rpx rgba(90, 60, 30, 0.08);
  transition: transform 0.2s, box-shadow 0.2s;
  background: var(--paper-deep);
}

.image-item.target {
  box-shadow: inset 6rpx 0 0 var(--accent);
}

.image-item.dragging {
  z-index: 10;
  transform: scale(1.05);
  box-shadow: var(--shadow-strong);
}

.image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn,
.rotate-btn {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  background: rgba(44, 36, 22, 0.55);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  backdrop-filter: blur(6px);
}

.delete-btn {
  top: 10rpx;
  right: 10rpx;
}

.rotate-btn {
  bottom: 10rpx;
  right: 10rpx;
}

.add-btn {
  width: 200rpx;
  height: 200rpx;
  background: rgba(154, 123, 79, 0.06);
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx dashed rgba(154, 123, 79, 0.35);
  box-sizing: border-box;
  padding: 0;
  margin: 0;
  line-height: 1.2;
  font-weight: normal;
}

.add-btn::after {
  border: none;
}

.add-btn-hover {
  background: rgba(154, 123, 79, 0.12);
}

.add-icon {
  font-size: 52rpx;
  line-height: 1;
  color: var(--accent);
}

.add-text {
  font-size: 20rpx;
  line-height: 1.35;
  text-align: center;
  color: var(--ink-soft);
  padding: 0 12rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(246, 241, 232, 0.94);
  backdrop-filter: saturate(180%) blur(18px);
  -webkit-backdrop-filter: saturate(180%) blur(18px);
  border-top: 0.5px solid var(--card-line);
  box-sizing: border-box;
}

.options-card {
  padding: 8rpx 28rpx;
  margin-bottom: 16rpx;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 0.5px solid var(--card-line);
}

.option-item-last {
  border-bottom: none;
}

.option-label {
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--ink);
}

.option-input {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 28rpx;
  color: var(--ink);
  background: var(--paper-deep);
  border-radius: 12rpx;
  padding: 10rpx 16rpx;
  border: 1rpx solid transparent;
}

.option-input-wide {
  max-width: 340rpx;
}

.option-placeholder {
  color: var(--ink-faint);
}

.button-group {
  display: flex;
  gap: 16rpx;
}

.history-btn,
.generate-btn {
  margin: 0;
  font-size: 32rpx;
  padding: 22rpx 0;
}

.history-btn {
  flex: 1;
}

.generate-btn {
  flex: 2;
}
